<Window x:Class="TimerAlarmPlugin.Display"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Display"
        Width="200" Height="60"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="White"
        Focusable="False"
        IsHitTestVisible="False">

    <Border Background="#FF000000"
        CornerRadius="0 20 20 0">

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="0" />
                <ColumnDefinition Width="Auto" MinWidth="99.027" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                VerticalAlignment="Center" Height="38" Margin="0,0,1,0">

                <TextBlock Name="TypeText"
                    FontSize="11"
                    Foreground="#CCFFFFFF"
                    Text="Timer"/>

                <TextBlock Name="IdText"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="food"/>
            </StackPanel>

            <TextBlock Name="TimeText"
                   Grid.Column="2"
                   Margin="10,0,0,0"
                   FontSize="24"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Text="00:00:00" Height="32" Width="88"/>
        </Grid>
    </Border>
</Window>